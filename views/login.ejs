<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — StreamKit</title>
  <meta name="description" content="Sign in to your StreamKit account to manage your live streams.">
  <link rel="icon" href="/images/logo.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.30.0/tabler-icons.min.css">
  <link rel="stylesheet" href="/css/streamkit-ui.css">
  <% if (typeof recaptchaSiteKey !== 'undefined' && recaptchaSiteKey) { %>
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>
  <% } %>
  <style>
    body {
      background: #0B0F1A;
      color: #F1F5F9;
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    .auth-wrap { width: 100%; max-width: 420px; position: relative; z-index: 1; }

    /* Input override to use sk-input style */
    .field-icon-wrap { position: relative; }
    .field-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #475569; font-size: .9rem; pointer-events: none; }
    .field-icon-right { position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #475569; padding: 4px; transition: color .2s; }
    .field-icon-right:hover { color: #F1F5F9; }
    .sk-input-icon { padding-left: 38px !important; }
    .sk-input-icon-r { padding-right: 40px !important; }

    /* Divider line */
    .auth-divider { display: flex; align-items: center; gap: .75rem; margin: 1.25rem 0; }
    .auth-divider span { flex: 1; height: 1px; background: rgba(255,255,255,.06); }
    .auth-divider p { font-size: .72rem; color: #475569; white-space: nowrap; }

    /* Error */
    .auth-error {
      display: flex; align-items: flex-start; gap: 10px;
      background: rgba(239,68,68,.07);
      border: 1px solid rgba(239,68,68,.2);
      border-radius: 10px;
      padding: 12px 14px;
      margin-bottom: 1.25rem;
      font-size: .82rem;
      color: #f87171;
    }
  </style>
</head>
<body>

<!-- Background -->
<div class="sk-grid-bg"></div>
<div style="position:fixed;inset:0;pointer-events:none;z-index:0;">
  <div class="sk-orb sk-orb-purple" style="width:700px;height:500px;top:-150px;left:50%;transform:translateX(-50%);"></div>
  <div class="sk-orb sk-orb-cyan"   style="width:300px;height:300px;bottom:-50px;right:-50px;"></div>
</div>

<div class="auth-wrap sk-fade-up">

  <!-- Brand -->
  <div style="text-align:center;margin-bottom:2rem;">
    <a href="/" style="display:inline-flex;flex-direction:column;align-items:center;gap:.75rem;text-decoration:none;">
      <div style="width:52px;height:52px;background:linear-gradient(135deg,#3B82F6,#8B5CF6);border-radius:14px;display:flex;align-items:center;justify-content:center;box-shadow:0 0 24px rgba(139,92,246,.4);">
        <i class="ti ti-broadcast" style="color:#fff;font-size:1.3rem;"></i>
      </div>
      <div>
        <div style="font-size:1.3rem;font-weight:800;letter-spacing:-.03em;color:#F1F5F9;">StreamKit</div>
        <div style="font-size:.75rem;color:#475569;margin-top:2px;">Live Streaming Control Center</div>
      </div>
    </a>
  </div>

  <!-- Card -->
  <div class="sk-auth-card">

    <div style="margin-bottom:1.5rem;">
      <h1 style="font-size:1.1rem;font-weight:700;margin-bottom:.25rem;">Welcome back</h1>
      <p style="font-size:.82rem;color:#475569;">Sign in to manage your streams</p>
    </div>

    <!-- Error -->
    <% if (error) { %>
    <div class="auth-error">
      <i class="ti ti-alert-circle" style="flex-shrink:0;margin-top:1px;"></i>
      <span><%= error %></span>
    </div>
    <% } %>

    <form action="/login" method="post" id="login-form" style="display:flex;flex-direction:column;gap:1rem;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <!-- Username -->
      <div>
        <label for="username" style="display:block;font-size:.78rem;font-weight:500;color:#94A3B8;margin-bottom:6px;">Username</label>
        <div class="field-icon-wrap">
          <i class="ti ti-user field-icon"></i>
          <input type="text" id="username" name="username" class="sk-input sk-input-icon"
            placeholder="Enter your username" autocomplete="username" required>
        </div>
      </div>

      <!-- Password -->
      <div>
        <label for="password" style="display:block;font-size:.78rem;font-weight:500;color:#94A3B8;margin-bottom:6px;">Password</label>
        <div class="field-icon-wrap">
          <i class="ti ti-lock field-icon"></i>
          <input type="password" id="password" name="password"
            class="sk-input sk-input-icon sk-input-icon-r"
            placeholder="Enter your password" autocomplete="current-password" required>
          <button type="button" class="field-icon-right" id="pw-toggle" onclick="togglePw()">
            <i class="ti ti-eye" id="pw-eye"></i>
          </button>
        </div>
      </div>

      <!-- reCAPTCHA -->
      <% if (typeof recaptchaSiteKey !== 'undefined' && recaptchaSiteKey) { %>
      <div><div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>" data-theme="dark"></div></div>
      <% } %>

      <!-- Submit -->
      <button type="submit" id="login-btn" class="sk-btn sk-btn-primary" style="width:100%;padding:.75rem;font-size:.9rem;border-radius:10px;margin-top:.25rem;">
        <i class="ti ti-login"></i> Sign In
      </button>
    </form>

    <div class="auth-divider"><span></span><p>don't have an account?</p><span></span></div>

    <a href="/signup" class="sk-btn sk-btn-ghost" style="width:100%;padding:.7rem;border-radius:10px;text-align:center;">
      <i class="ti ti-user-plus"></i> Create Account
    </a>

  </div>

  <p style="text-align:center;font-size:.7rem;color:#334155;margin-top:1.25rem;">
    StreamKit &mdash; Streaming Control Center
  </p>
</div>

<script>
  // Auto-focus
  const hasError = document.querySelector('.auth-error');
  if (!hasError) { const u = document.getElementById('username'); if(u) u.focus(); }

  // Submit loading
  document.getElementById('login-form').addEventListener('submit', function() {
    const btn = document.getElementById('login-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="ti ti-loader" style="animation:sk-spin 1s linear infinite;"></i> Signing in…';
  });

  // Toggle password
  function togglePw() {
    const pw = document.getElementById('password');
    const eye = document.getElementById('pw-eye');
    if (pw.type === 'password') {
      pw.type = 'text';
      eye.classList.replace('ti-eye','ti-eye-off');
    } else {
      pw.type = 'password';
      eye.classList.replace('ti-eye-off','ti-eye');
    }
  }
</script>
</body>
</html>
